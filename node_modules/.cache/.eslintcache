"messages":"32","suppressedMessages":"33","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"34"},{"filePath":"35","messages":"36","suppressedMessages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","suppressedMessages":"40","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"41","messages":"42","suppressedMessages":"43","errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"44"},{"filePath":"45","messages":"46","suppressedMessages":"47","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"48","messages":"49","suppressedMessages":"50","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"51","messages":"52","suppressedMessages":"53","errorCount":0,"fatalErrorCount":0,"warningCount":14,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"54","messages":"55","suppressedMessages":"56","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"57"},{"filePath":"58","messages":"59","suppressedMessages":"60","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/index.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/App.js",["61","62","63","64"],[],"\n\nimport './App.css';\nimport React from 'react';\n\nimport {BrowserRouter, Route, Routes} from \"react-router-dom\"\nimport  { useReducer, useRef, useEffect} from 'react';\nimport { useState } from 'react';\n\n\n\n// pages \nimport Review from './pages/Review'\nimport Like from './pages/Like'\nimport MyPage from './pages/MyPage';\nimport Home from './pages/Home';\nimport Auth from \"./pages/Auth\";\nimport Login from \"./pages/Login\";\nimport GoogleButton from './pages/GoogleButton';\n\n\nexport const DiaryStateContext = React.createContext();\n\nexport const DiraryDispatchContext = React.createContext();\n\nconst dummyData = [\n  {\n    id : 1,\n    name : 'Julia',\n    level : 'best'\n\n  }\n\n]\n\nfunction App() {\n\n  // const [ < 상태 객체 >, < dispatch 함수 > ]\n\n  \n\n  return (\n    <DiaryStateContext.Provider value={dummyData}>\n      <DiraryDispatchContext.Provider>\n      \n        <BrowserRouter>\n          <div className = \"App\">\n\n            <Routes>\n              <Route path =\"/\" element = {<Home/>} />\n              <Route path=\"/oauth/kakao/callback\" element={<Authcheck />} />\n              <Route path=\"/login\" element={<Login />} />\n              <Route path=\"/login1\" element={<GoogleButton />} />\n              <Route path=\"/review\" element = {<Review/>} />\n              <Route path=\"/like\" element = {<Like/>} />\n              <Route path='/mypage' element = {<MyPage/>} />\n\n            </Routes>\n          </div>\n\n        </BrowserRouter>\n      </DiraryDispatchContext.Provider>\n      </DiaryStateContext.Provider>\n      \n  );\n}\n\nexport default App;\n\n\n\nfunction Authcheck() {\n  return Auth()\n}","/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/MyPage.js",["65"],[],"import MyButton from \"../components/MyButton\";\nimport {DiaryStateContext} from \"../App\";\nimport { useContext } from \"react\";\n\n\nconst MyPage= () => {\n\n   const userinfo = useContext(DiaryStateContext);\n   console.log(\"userinfo\",userinfo);\n\n   return <div className=\"userinfo\">\n      \n         <h3> \n            name :{ userinfo[0].name}\n            <br/>\n            LV : {userinfo[0].level}\n         </h3>\n\n   </div>\n}\n\nexport default MyPage;","/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Like.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Review.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Home.js",["66","67","68","69","70"],[],"import React, { useContext, useState  } from \"react\";\nimport MyHeader from './../components/MyHeader';\nimport MyButton from './../components/MyButton';\nimport { useNavigate } from \"react-router-dom\";\nimport {DiaryStateContext} from \"../App\";\nimport MyPage from \"./MyPage\";\nimport Login from \"./Login\";\n\nconst env = process.env;\nenv.PUBLIC_URL  = env.PUBLIC_URL || \"\";\nconst flavor_img = process.env.PUBLIC_URL + `/assets/flavor.png`;\nconst meat_img = process.env.PUBLIC_URL + `/assets/meat.png`;\nconst spicy_img = process.env.PUBLIC_URL + `/assets/spicy.png`;\n\n\nconst Home = ({dummyData}) => {\n    const navigate = useNavigate();\n    const userinfo = useContext(DiaryStateContext);\n   \n    const [flavor, setflavor] = useState();\n    const handleClickRadioButton1 = (e) =>{\n      console.log(e.target.value);\n      setflavor(e.target.value)\n    }\n\n    const [spicy, setspicy] = useState();\n    const handleClickRadioButton2 = (e) =>{\n      console.log(e.target.value);\n      setspicy(e.target.value)\n    }\n\n    const [meat, setmeat] = useState();\n    const handleClickRadioButton3 = (e) =>{\n      console.log(e.target.value);\n      setmeat(e.target.value)\n    }\n\n\n\n    return (\n      <div className=\"Home\">\n        <MyHeader headText={\"당신의 MARR\"} />\n        \n        <MyPage/>\n\n        <div className=\"side\">\n          <MyButton text={'리뷰 모아보기'} onClick={() => navigate('/review')}/>\n\n          <MyButton c text={'내가 찜한 마라'} onClick={() => navigate('/like')}/>\n        </div>\n\n\n        <div className=\"marr_type\">\n          <h2>나의 마라 취향</h2>\n          <div className = \"type\">\n          <h3>향신료  <img src={flavor_img}  style={{ width: '3%'}} /> </h3>\n\n            <label>\n            <input\n                type=\"radio\"\n                value = \"1\"\n                checked = {flavor===\"1\"}\n                onChange = {handleClickRadioButton1}\n              />\n                상\n              </label>\n              <label>\n              <input\n                type=\"radio\"\n                value = \"2\"\n                checked = {flavor===\"2\"}\n                onChange = {handleClickRadioButton1}\n              />\n                중\n              </label>\n              <label>\n              <input\n                type=\"radio\"\n                value = \"3\"\n                checked = {flavor===\"3\"}\n                onChange = {handleClickRadioButton1}\n              />\n                하\n              </label>\n\n\n            <h3>맵기  <img src={spicy_img}  style={{ width: '3%'}} /></h3>\n            <label>\n            <input\n                type=\"radio\"\n                value = \"1\"\n                checked = {spicy===\"1\"}\n                onChange = {handleClickRadioButton2}\n              />\n                상\n              </label>\n              <label>\n              <input\n                type=\"radio\"\n                value = \"2\"\n                checked = {spicy===\"2\"}\n                onChange = {handleClickRadioButton2}\n              />\n                중\n              </label>\n              <label>\n              <input\n                type=\"radio\"\n                value = \"3\"\n                checked = {spicy===\"3\"}\n                onChange = {handleClickRadioButton2}\n              />\n                하\n              </label>\n\n            <h3>고기종류  <img src={meat_img}  style={{ width: '3%'}} /></h3>\n              <label>\n              <input\n                  type=\"radio\"\n                  value = \"1\"\n                  checked = {meat===\"1\"}\n                  onChange = {handleClickRadioButton3}\n                />\n                  양고기\n                </label>\n                <label>\n                <input\n                  type=\"radio\"\n                  value = \"2\"\n                  checked = {meat===\"2\"}\n                  onChange = {handleClickRadioButton3}\n                />\n                  소고기\n                </label>\n                <label>\n                <input\n                  type=\"radio\"\n                  value = \"3\"\n                  checked = {meat===\"3\"}\n                  onChange = {handleClickRadioButton3}\n                />\n                  둘다\n                </label>\n\n          </div>\n        </div>\n\n\n      </div>\n      )\n}\n\nexport default Home;","/Users/gwagsuchan/Project/miniProject/marr_react-app/src/components/MyHeader.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/components/MyButton.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Login.js",["71","72","73","74","75","76","77","78","79","80","81","82","83","84"],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Auth.js",["85","86"],[],"import React from \"react\";\nimport { useEffect } from \"react\";\nimport axios from \"axios\";\nimport qs from \"qs\";\nimport { useNavigate } from \"react-router-dom\";\n\nconst Auth = () => {\n  const REST_API_KEY = \"32bb1444ddc8c71c3924daaef84ae5e6\";\n  const REDIRECT_URI = \"http://localhost:3000/oauth/kakao/callback\";\n  const CLIENT_SECRET = \"deR1ymtr9b0Us4aqf6wzzr9cWmi4qyDY\";\n\n  // calllback으로 받은 인가코드\n  const code = new URL(window.location.href).searchParams.get(\"code\");\n\n  const history = useNavigate();\n\n  const getToken = async () => {\n    const payload = qs.stringify({\n      grant_type: \"authorization_code\",\n      client_id: REST_API_KEY,\n      redirect_uri: REDIRECT_URI,\n      code: code,\n      client_secret: CLIENT_SECRET,\n    });\n\n    try {\n      // access token 가져오기\n      const res = await axios.post(\n        \"https://kauth.kakao.com/oauth/token\",\n        payload\n      );\n      \n      // Kakao Javascript SDK 초기화\n      window.Kakao.init(REST_API_KEY);\n      // access token 설정\n      window.Kakao.Auth.setAccessToken(res.data.access_token);\n      history.replace(\"/profile\");\n    } catch (err) {\n      console.log(err);\n    }\n  };\n\n  useEffect(() => {\n    getToken();\n  }, []);\n\n  return null;\n};\n\nexport default Auth;","/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/GoogleButton.js",[],[],{"ruleId":"87","severity":1,"message":"88","line":7,"column":11,"nodeType":"89","messageId":"90","endLine":7,"endColumn":21},{"ruleId":"87","severity":1,"message":"91","line":7,"column":23,"nodeType":"89","messageId":"90","endLine":7,"endColumn":29},{"ruleId":"87","severity":1,"message":"92","line":7,"column":31,"nodeType":"89","messageId":"90","endLine":7,"endColumn":40},{"ruleId":"87","severity":1,"message":"93","line":8,"column":10,"nodeType":"89","messageId":"90","endLine":8,"endColumn":18},{"ruleId":"87","severity":1,"message":"94","line":1,"column":8,"nodeType":"89","messageId":"90","endLine":1,"endColumn":16},{"ruleId":"87","severity":1,"message":"95","line":7,"column":8,"nodeType":"89","messageId":"90","endLine":7,"endColumn":13},{"ruleId":"87","severity":1,"message":"96","line":18,"column":11,"nodeType":"89","messageId":"90","endLine":18,"endColumn":19},{"ruleId":"97","severity":1,"message":"98","line":56,"column":20,"nodeType":"99","endLine":56,"endColumn":68},{"ruleId":"97","severity":1,"message":"98","line":87,"column":21,"nodeType":"99","endLine":87,"endColumn":68},{"ruleId":"97","severity":1,"message":"98","line":116,"column":23,"nodeType":"99","endLine":116,"endColumn":69},{"ruleId":"87","severity":1,"message":"100","line":2,"column":10,"nodeType":"89","messageId":"90","endLine":2,"endColumn":23},{"ruleId":"87","severity":1,"message":"101","line":2,"column":41,"nodeType":"89","messageId":"90","endLine":2,"endColumn":46},{"ruleId":"87","severity":1,"message":"102","line":2,"column":48,"nodeType":"89","messageId":"90","endLine":2,"endColumn":54},{"ruleId":"87","severity":1,"message":"103","line":2,"column":56,"no