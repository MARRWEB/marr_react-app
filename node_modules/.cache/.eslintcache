ult MyPage;",[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Like.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Review.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Home.js",["57","58","59","60"],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/components/MyHeader.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/components/MyButton.js",[],[],"/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/Auth.js",["61","62"],[],"import React from \"react\";\nimport { useEffect } from \"react\";\nimport axios from \"axios\";\nimport qs from \"qs\";\nimport { useNavigate } from \"react-router-dom\";\n\nconst Auth = () => {\n  const REST_API_KEY = \"32bb1444ddc8c71c3924daaef84ae5e6\";\n  const REDIRECT_URI = \"http://localhost:3000/oauth/kakao/callback\";\n  const CLIENT_SECRET = \"deR1ymtr9b0Us4aqf6wzzr9cWmi4qyDY\";\n\n  // calllback으로 받은 인가코드\n  const code = new URL(window.location.href).searchParams.get(\"code\");\n\n  const history = useNavigate();\n\n  const getToken = async () => {\n    const payload = qs.stringify({\n      grant_type: \"authorization_code\",\n      client_id: REST_API_KEY,\n      redirect_uri: REDIRECT_URI,\n      code: code,\n      client_secret: CLIENT_SECRET,\n    });\n\n    try {\n      // access token 가져오기\n      const res = await axios.post(\n        \"https://kauth.kakao.com/oauth/token\",\n        payload\n      );\n      \n      // Kakao Javascript SDK 초기화\n      window.Kakao.init(REST_API_KEY);\n      // access token 설정\n      window.Kakao.Auth.setAccessToken(res.data.access_token);\n      history.replace(\"/profile\");\n    } catch (err) {\n      console.log(err);\n    }\n  };\n\n  useEffect(() => {\n    getToken();\n  }, []);\n\n  return null;\n};\n\nexport default Auth;","/Users/gwagsuchan/Project/miniProject/marr_react-app/src/pages/GoogleButton.js",[],[],{"ruleId":"63","severity":1,"message":"64","line":5,"column":10,"nodeType